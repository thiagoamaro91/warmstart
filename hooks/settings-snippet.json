{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/hooks/context-keeper.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/hooks/block-destructive-bash.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/hooks/block-em-dash.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/hooks/guard-memory-size.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/hooks/guard-context-index-size.sh"
          }
        ]
      }
    ]
  }
}
