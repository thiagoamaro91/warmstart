{
  "hooks": {
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/context-keeper.sh\"" } ] }
    ],
    "PreToolUse": [
      { "matcher": "Bash", "hooks": [ { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/block-destructive-bash.sh\"" } ] },
      { "matcher": "Write|Edit", "hooks": [
        { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/guard-memory-size.sh\"" },
        { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/guard-context-index-size.sh\"" }
      ] }
    ]
  }
}
